# ------------------------------------------------------------------------------
# CLIENT ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------

# [OPTIONAL] URL of the local frontend (Default: http://localhost:3000)
NEXT_PUBLIC_LOCAL_FRONTEND_URL=http://localhost:3000

# [OPTIONAL] URL of the production frontend
NEXT_PUBLIC_SERVER_FRONTEND_URL=https://your-frontend-domain.com

# [OPTIONAL] URL of the local backend API (Default: http://localhost:5001/api/v1)
NEXT_PUBLIC_LOCAL_BACKEND_URL=http://localhost:5001/api/v1

# [OPTIONAL] URL of the production backend API
NEXT_PUBLIC_SERVER_BACKEND_URL=https://your-backend-domain.com/api/v1

# [REQUIRED] Razorpay API Key ID (Public key for client-side checkout)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_placeholder_key_id
