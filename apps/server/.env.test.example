# ------------------------------------------------------------------------------
# SERVER ENVIRONMENT CONFIGURATION (TEST OVERRIDES)
# ------------------------------------------------------------------------------

# [REQUIRED] Must be "test" for Vitest integration
NODE_ENV=test

# [REQUIRED] The dedicated test database connection string. MUST differ from DATABASE_URL.
TEST_DATABASE_URL=postgresql://user:password@host/test_db

# [REQUIRED] Secret for signing Access JWTs in tests
JWT_ACCESS_SECRET=test_access_secret_placeholder_min_32_chars_long

# [REQUIRED] Secret for signing Refresh JWTs in tests
JWT_REFRESH_SECRET=test_refresh_secret_placeholder_min_32_chars_long
