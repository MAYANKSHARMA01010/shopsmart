# ------------------------------------------------------------------------------
# SERVER ENVIRONMENT CONFIGURATION
# ------------------------------------------------------------------------------

# [REQUIRED] Node Environment. Must be one of: development, test, production
NODE_ENV=development

# [OPTIONAL] Application port (Default: 5001)
SERVER_PORT=5001

# [REQUIRED] The main development/production database connection string
DATABASE_URL=postgresql://user:password@host/dev_db

# [OPTIONAL] Dedicated test database. DO NOT equal DATABASE_URL.
TEST_DATABASE_URL=postgresql://user:password@host/test_db

# [OPTIONAL] Local Redis connection string (Default: redis://localhost:6379)
REDIS_LOCAL_URL=redis://localhost:6379

# [OPTIONAL] Production Redis connection string
REDIS_SERVER_URL=redis://user:pass@host:port

# [REQUIRED] Secret for signing Access JWTs (min 32 chars)
JWT_ACCESS_SECRET=access_secret_placeholder_min_32_chars_long

# [REQUIRED] Secret for signing Refresh JWTs (min 32 chars)
JWT_REFRESH_SECRET=refresh_secret_placeholder_min_32_chars_long

# [OPTIONAL] Access JWT Expiration (Default: 15m)
JWT_ACCESS_EXPIRES_IN=15m

# [OPTIONAL] Refresh JWT Expiration (Default: 7d)
JWT_REFRESH_EXPIRES_IN=7d

# [REQUIRED] Razorpay API Key ID
RAZORPAY_KEY_ID=rzp_test_placeholder_key_id

# [REQUIRED] Razorpay API Key Secret
RAZORPAY_KEY_SECRET=your_razorpay_secret_placeholder

# [REQUIRED] Razorpay Webhook Secret for payload validation
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_placeholder

# [OPTIONAL] Bcrypt salt rounds (Default: 12)
BCRYPT_SALT_ROUNDS=12

# [OPTIONAL] Winston log level (Default: info)
LOG_LEVEL=info

# [OPTIONAL] Winston log format (Default: text)
LOG_FORMAT=text

# [OPTIONAL] URL of the local frontend (Default: http://localhost:3000)
FRONTEND_LOCAL_URL=http://localhost:3000

# [OPTIONAL] URL of the production frontend
FRONTEND_SERVER_URL=https://your-frontend-domain.com

# [OPTIONAL] URL of the local backend API (Default: http://localhost:5001)
BACKEND_LOCAL_URL=http://localhost:5001

# [OPTIONAL] URL of the production backend API
BACKEND_SERVER_URL=https://your-backend-domain.com
