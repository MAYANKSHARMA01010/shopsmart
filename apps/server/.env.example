# Server Configuration
SERVER_PORT=5001
NODE_ENV=development
# NODE_ENV=production

# Frontend URLs (Used for CORS and redirects)
FRONTEND_LOCAL_URL=http://localhost:3000
FRONTEND_SERVER_URL=https://shopsmart.example.com

# Backend URLs
BACKEND_LOCAL_URL=http://localhost:5001
BACKEND_SERVER_URL=https://api.shopsmart.example.com

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&pgbouncer=true

# Redis Configuration (optional — app degrades gracefully without it)
REDIS_LOCAL_URL=redis://localhost:6379
REDIS_SERVER_URL=redis://your_redis_hosted_url:6379

# JWT Secrets — Generate with: openssl rand -hex 32
# These MUST be set in production. Never commit real values.
JWT_SECRET=REPLACE_WITH_AT_LEAST_32_CHAR_SECRET
JWT_ACCESS_SECRET=REPLACE_WITH_AT_LEAST_32_CHAR_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_A_DIFFERENT_32_CHAR_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Payment Gateways (optional — only required if using payment features)
RAZORPAY_KEY_ID=rzp_live_XXXXXXXX
RAZORPAY_KEY_SECRET=REPLACE_WITH_RAZORPAY_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
# STRIPE_SECRET_KEY=sk_live_XXXXXXXX
