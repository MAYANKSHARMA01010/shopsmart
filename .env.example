# EC2 Deployment Configuration
# Copy this file to .env and fill in your actual values

# The ID of your EC2 instance
INSTANCE_ID="your_instance_id_here"

# The Public IP of your EC2 instance 
TARGET_IP="your_public_ip_here"

# The AWS region where your instance is located
REGION="us-east-1"

# The name of your SSH key pair (without .pem)
KEY_NAME="vockey"

# The default user for your EC2 instance (usually 'ubuntu' for Ubuntu or 'ec2-user' for Amazon Linux)
EC2_USER="ubuntu"
