{
  "name": "shopsmart-server",
  "version": "1.0.0",
  "description": "Backend API for ShopSmart",
  "main": "src/server.ts",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "prisma generate && tsc",
    "test": "prisma generate && vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "prisma generate && vitest run --coverage",
    "lint": "eslint .",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "6.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.4.1",
    "zod": "^3.24.1",
    "express-rate-limit": "^8.4.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.3",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "globals": "^15.0.0",
    "nodemon": "^3.1.14",
    "prisma": "6.2.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.3"
  }
}
